#to open file for read operation
filev = open("firstfile.txt","r")

#to check file is open or not
if(filev):
    
    #to read data from file
    data = filev.readline()
    
    count = 0
    
    if(data):
        print("Counting vowels in file : ")
        
        while(data):
            for ch in data:
                if(ch in "aeiouAEIOU"):
                    count = count + 1
            
            data = filev.readline()
        
        print("Number of vowels : ",count)
    
    else:
        print("File is empty")
    
    #closing file
    filev.close()

else:
    print("Unable to open the file")
